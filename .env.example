# Demo Barber - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ===========================================
# API KEYS (Required)
# ===========================================

# Gemini API Key for AI features
# Get it from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ===========================================
# APPLICATION CONFIGURATION (Optional)
# ===========================================

# Application URL (auto-detected in production)
APP_URL="http://localhost:5173"

# Application name
APP_NAME="Demo Barber"

# Application version
APP_VERSION="1.0.0"

# ===========================================
# EXTERNAL SERVICES (Optional)
# ===========================================

# Analytics service ID
# VITE_ANALYTICS_ID="your_analytics_id"

# API base URL for backend services
# VITE_API_URL="https://api.example.com"

# ===========================================
# DEVELOPMENT SETTINGS (Optional)
# ===========================================

# Enable debug mode (development only)
# VITE_DEBUG=true

# API timeout in milliseconds
# VITE_API_TIMEOUT=5000

# ===========================================
# IMPORTANT NOTES
# ===========================================
# 1. NEVER commit .env.local to version control
# 2. Keep this file (.env.example) in version control
# 3. Use different values for development and production
# 4. All VITE_* variables are exposed to the client
# 5. Only GEMINI_API_KEY should be kept secret
